# Supabase Configuration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_your_anon_key_here"

# DEEPSEEK_API_KEY: API Key for DeepSeek chat model (客服对话).
# Get it from https://platform.deepseek.com/
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# ZHIPU_API_KEY: API Key for ZhipuAI GLM-4V vision model (OCR图片识别).
# Get it from https://open.bigmodel.cn/
ZHIPU_API_KEY="your-zhipu-api-key"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
